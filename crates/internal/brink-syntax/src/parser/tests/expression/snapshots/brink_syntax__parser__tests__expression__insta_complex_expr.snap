---
source: crates/internal/brink-syntax/src/parser/tests/expression.rs
expression: "format!(\"{:#?}\", p.syntax())"
---
SOURCE_FILE@0..16
  LOGIC_LINE@0..16
    TILDE@0..1 "~"
    WHITESPACE@1..2 " "
    ASSIGNMENT@2..15
      PATH@2..3
        IDENT@2..3 "x"
      WHITESPACE@3..4 " "
      EQ@4..5 "="
      WHITESPACE@5..6 " "
      INFIX_EXPR@6..15
        INTEGER_LIT@6..7
          INTEGER@6..7 "1"
        WHITESPACE@7..8 " "
        PLUS@8..9 "+"
        WHITESPACE@9..10 " "
        INFIX_EXPR@10..15
          INTEGER_LIT@10..11
            INTEGER@10..11 "2"
          WHITESPACE@11..12 " "
          STAR@12..13 "*"
          WHITESPACE@13..14 " "
          INTEGER_LIT@14..15
            INTEGER@14..15 "3"
    NEWLINE@15..16 "\n"
