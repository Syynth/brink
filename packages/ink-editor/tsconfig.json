{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "brink-web": ["../../crates/brink-web/www/pkg/brink_web.js"],
      "@brink/wasm-types": ["../wasm-types/src/index.ts"],
      "@brink/wasm": ["../wasm/src/index.ts"],
      "@brink/ink-operations": ["../ink-operations/src/index.ts"]
    }
  },
  "include": ["src"]
}
