{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@brink/ink-operations": ["../ink-operations/src/index.ts"],
      "@brink/wasm-types": ["../wasm-types/src/index.ts"],
      "@brink/studio-store": ["../studio-store/src/index.ts"]
    }
  },
  "include": ["src"]
}
