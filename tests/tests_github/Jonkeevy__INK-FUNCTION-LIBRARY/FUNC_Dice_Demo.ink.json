",7,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_7SEVEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",8,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_8EIGHT.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",9,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_9NINE.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",10,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_10TEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",11,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_11ELEVEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",12,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_12TWELVE.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",13,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_13THIRTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",14,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_14FOURTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",15,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_15FIFTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",16,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_16SIXTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",17,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_17SEVENTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",18,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_18EIGHTEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",19,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_19NINETEEN.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],["du","ev",20,"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^[img]IMAGES/D20_20TWENTY.png[/img] ","<>","\n",{"->":".^.^.^.25"},null]}],[{"->":".^.b"},{"b":["pop","\n","^not a D20.","\n",{"->":".^.^.^.25"},null]}],"nop","\n",null],"StartDiceDemo":[["^[banner style=accent]WELCOME TO THE ROLLER INK[/banner]","\n","^[banner][img]IMAGES/D3_1ONE.png[/img] [img]IMAGES/D3_3THREE.png[/img] [img]IMAGES/D3_1ONE.png[/img] [img]IMAGES/D3_2TWO.png[/img][/banner]","\n","ev","str","^WHAT'S ALL THIS THEN?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^ATRAMENT","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ",{"->":"demoROLLER"},"\n",{"->":".^.^.g-0"},null],"c-1":["^ ",{"->t->":"AtramentUI"},"\n",{"->":".^.^.g-0"},null],"g-0":[{"->":".^.^.^"},null]}],null],"demoROLLER":[["^This here is a Dice Roller.","\n","^Well, No. Actually that's a lie. This is an explainer on adding dice rolling to your Ink projects using the functions I've made.","\n","^It includes some dice rolling, but mostly it unpacks how the different functions work behind the scenes. And why I made some decisions.","\n","^If you're familiar with Ink you can probably grok what I was up to without all this. Just download the files you want.","\n","ev","str","^START AT THE BEGINNING","/str","/ev",{"*":".^.c-0","flg":4},["ev",{"^->":"demoROLLER.0.14.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-1","flg":2},{"s":["^CHOOSE A TOPIC ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-0":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.Intro"},{"->":".^.^.Menu"},null],"c-1":["ev",{"^->":"demoROLLER.0.c-1.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.14.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.Menu"},null],"Menu":["ev","str","^INTRODUCTION","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^ROLLING ONE DICE","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^VARYING THE NUMBER OF SIDES","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^ROLLING MULTIPLE DICE ","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^SUM TOTALS","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^SHOWING EACH ROLL","/str","/ev",{"*":".^.c-7","flg":4},"ev","str","^SHOW AND TOTALS","/str","/ev",{"*":".^.c-8","flg":4},"ev","str","^NARRATING ROLLS","/str","/ev",{"*":".^.c-9","flg":4},"ev","str","^SUCCESS","/str","/ev",{"*":".^.c-10","flg":4},"ev","str","^SUM TOTAL CHECK","/str","/ev",{"*":".^.c-11","flg":4},"ev","str","^INDIVIDUAL ROLL SUCCESS","/str","/ev",{"*":".^.c-12","flg":4},"ev","str","^SUCCESS COUNTS","/str","/ev",{"*":".^.c-13","flg":4},"ev","str","^MODIFIERS","/str","/ev",{"*":".^.c-14","flg":4},{"c-2":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Intro"},{"->":".^.^.^.Intro"},null],"c-3":["^  ","#","^CLEAR","/#","\n",{"->":".^.^.^.OneDice"},{"->":".^.^.^.Intro"},null],"c-4":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.ManySides"},{"->":".^.^.^.Intro"},null],"c-5":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.DicePool"},{"->":".^.^.^.Intro"},null],"c-6":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Total"},{"->":".^.^.^.Intro"},null],"c-7":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Show"},{"->":".^.^.^.Intro"},null],"c-8":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Tally"},{"->":".^.^.^.Intro"},null],"c-9":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.narrate_"},{"->":".^.^.^.Intro"},null],"c-10":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Success"},{"->":".^.^.^.Intro"},null],"c-11":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.SumTotalSuccess"},{"->":".^.^.^.Intro"},null],"c-12":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.IndividualRollSuccess"},{"->":".^.^.^.Intro"},null],"c-13":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.SuccessCounts"},{"->":".^.^.^.Intro"},null],"c-14":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Modifiers"},{"->":".^.^.^.Intro"},null]}],"Intro":["^[banner]ONLY ONE DICE[/banner]","\n","^Here, take this ordinary 6-sided die. You know what to do!","\n","ev","str","^ROLL IT","/str","/ev",{"*":".^.c-15","flg":4},{"c-15":["\n",{"->":".^.^.^.OneDice"},null]}],"OneDice":["^You rolled the d6. It came up ","ev",{"f()":"1d6"},"out","/ev","^. (Trust me.)","\n","^The basis of dice rolling is Ink's RANDOM function. It takes 2 parameters that set the range of the integer it'll return.","\n","^For a six-sided die the parameters are set to ( 1 , 6 ).","\n","^[info side=highlight]Function: 1d6() is RANDOM(1, 6)[/info]","\n","ev","str","^EASY, NEXT","/str","/ev",{"*":".^.c-16","flg":4},{"c-16":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.ManySides"},null]}],"ManySides":["^[banner]ONE DICE, MANY SIDES[/banner]","\n","^Next step we'll make the dice versatile. We want to be able to roll a dice of any shape, with any number of sides. We start with a function to return one roll of a dice with Y number of sides.","\n","^[info side=accent]Term: Y means number of sides of the dice in the pool. [/info]","\n","^How many sides do you want?","\n","ev","str","^One 6-sided die","/str","/ev",{"*":".^.c-17","flg":4},"ev","str","^One 10-sided die","/str","/ev",{"*":".^.c-18","flg":4},"ev","str","^One 20-sided die","/str","/ev",{"*":".^.c-19","flg":4},{"c-17":["\n","^You rolled the d6. It came up ","ev",6,{"f()":"1dY"},"out","/ev","^.","\n",{"->":".^.^.^.g-0"},null],"c-18":["\n","^You rolled the d10. It came up ","ev",10,{"f()":"1dY"},"out","/ev","^.","\n",{"->":".^.^.^.g-0"},null],"c-19":["\n","^You rolled the d20. It came up ","ev",20,{"f()":"1dY"},"out","/ev","^.","\n",{"->":".^.^.^.g-0"},null]}],"g-0":["^This is the foundation of all the following functions: '1dY' where Y is the upper bound of the RANDOM function.","\n","^[info side=highlight]Function: 1dY(y) = RANDOM(1, y)[/info]","\n","ev","str","^ONWARD","/str","/ev",{"*":".^.c-20","flg":4},{"c-20":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.DicePool"},null]}],"DicePool":["^[banner]DICE POOL[/banner]","\n","^Next up let's roll multiple dice - a Dice Pool. All the functions use X for the number of dice to roll and Y for the number of sides. So it's called 'XdY'","\n","^[info side=accent]Term: X means number of dice in the pool. [/info]","\n","^Rolling X number of times uses a recursive instruction to repeat the roll.","\n","^[info side=highlight]Function: XdY(x, y)[/info]","\n","^Here, roll this dice pool of 5 seven-sided dice.","\n",["ev",{"^->":"demoROLLER.0.DicePool.12.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-21","flg":2},{"s":["^ROLL THEM",{"->":"$r","var":true},null]}],{"c-21":["ev",{"^->":"demoROLLER.0.DicePool.c-21.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.12.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.Total"},null]}],"Total":["^You rolled 5 seven-sided dice and...","\n","^Um...","\n","^How should the results be shown?","\n","ev","str","^ADD THEM UP","/str","/ev",{"*":".^.c-22","flg":4},{"c-22":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.g-1"},null]}],"g-1":["^[banner]SUM TOTAL[/banner]","\n","^The Sum Total of the dice pool is ","ev",5,7,{"f()":"total_XdY"},"out","/ev","^. This is a 'total_' function. It calls 1dY called X times and each result is added to the ongoing total.","\n","^[info side=accent]Term: total_ means the sum of the dice pool. [/info]","\n","^[info side=highlight]Function: total_XdY(x, y)[/info]","\n",["ev",{"^->":"demoROLLER.0.g-1.15.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-23","flg":2},{"s":["^BORING",{"->":"$r","var":true},null]}],{"c-23":["ev",{"^->":"demoROLLER.0.g-1.c-23.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.15.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.Show"},null]}],"Show":["^I agree.","\n","^Sum totals are useful but dull. It's exciting to see the individual rolls of the dice pool. So let's do that again but use the 'show_' function.","\n","ev","str","^SHOW ME THE SHOW","/str","/ev",{"*":".^.c-24","flg":4},{"c-24":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.g-2"},null]}],"g-2":["^[banner]SHOW THE ROLL[/banner]","\n","^Here - 5 six-sided dice.","\n",["ev",{"^->":"demoROLLER.0.g-2.4.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-25","flg":2},{"s":["^ROLL THEM",{"->":"$r","var":true},null]}],{"c-25":["ev",{"^->":"demoROLLER.0.g-2.c-25.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.4.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-3"},null]}],"g-3":["^You rolled 5 six-sided dice and got: ","ev",5,6,{"f()":"show_XdY"},"out","/ev","^. Look at all those numbers. Nice.","\n","^[info side=highlight]Function: show_XdY(x, y)[/info]","\n","^You can edit the function to have different dividers between the results. Spaces, commas, pipes, etc.","\n","^The function also needs '<>' - Ink's 'glue' used to close line-breaks.","\n","^If you want to show images of the roll you can do that in your game engine.","\n","^[info side=highlight]","ev",5,{"f()":"ATRMNT_IMGshow_Xd6"},"out","/ev","^[/info]","\n","^For this demo I used Atrament Web UI and some basic images I made. Want to see? Or want to carry on with standard Ink first?","\n","ev","str","^CARRY ON WITH INK","/str","/ev",{"*":".^.c-26","flg":4},"ev","str","^SHOW ME ATRAMENT DICE","/str","/ev",{"*":".^.c-27","flg":4},{"c-26":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Tally"},null],"c-27":["^ ","#","^CLEAR","/#","\n",{"->t->":"AtramentUI"},{"->":".^.^.^.Tally"},null]}],"Tally":["^[banner]TALLY HO! SHOW & TOTAL[/banner]","\n","^What we really want is to combine the total and show functions - so I use 'tally_' to show both.","\n","^Roll these 4 four-sided dice.","\n",["ev",{"^->":"demoROLLER.0.Tally.6.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-28","flg":2},{"s":["^ROLL THEM",{"->":"$r","var":true},null]}],{"c-28":["ev",{"^->":"demoROLLER.0.Tally.c-28.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.6.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-4"},null]}],"g-4":["^[info]","ev",4,4,{"f()":"narrate_XdY"},"out","/ev","^[/info]","\n","^Now we're cooking!","\n","^Understanding the tally_ function took me a while even though I made it up. (Thanks for the patient explanation from IFcoltransG on the Inkle Discord).","\n","^Tally_ function prints the individual rolls while also returning a total of the rolls. It does  two things!","\n","^This means it that when wrapped in {...} it prints the show_ immediately followed by the total_ in a single string. Like so: [info side=highlight]Function: tally_XdY(x, y) prints ","ev",4,4,{"f()":"tally_XdY"},"out","/ev","^ [/info]","\n","^Which doesn't read very well. At all.","\n","^But if the function is run with ~ and given a temp variable to hold the total, then the string of results and the total can be printed nicely.","\n","ev","str","^PRINT?","/str","/ev",{"*":".^.c-29","flg":4},{"c-29":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.narrate_"},null]}],"narrate_":["^[banner]NARRATE THE ROLL![/banner]","\n","^I'm abusing the term 'print' which actually means 'to put on the screen'. You'll notice in the Ink syntax that the full sentence presenting the tally comes from a function. Instead of calling this 'print' let's use 'narrate_'.","\n","^The purpose of narrate_ functions are to wrap up the results of other functions into a tidy NARRATIVE package. narrate_ functions are the end of the line - next stop: the player's brain. Or another narrate_ function. Speaking of which...","\n","ev","str","^GO ON","/str","/ev",{"*":".^.c-30","flg":4},{"c-30":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Success"},null]}],"Success":["^[banner]SUCCESS & FAILURE[/banner]","\n","^Onward! Did your roll succeed?","\n",["ev",{"^->":"demoROLLER.0.Success.4.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-31","flg":2},{"s":["^YUP",{"->":"$r","var":true},null]}],["ev",{"^->":"demoROLLER.0.Success.5.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-32","flg":2},{"s":["^NOPE",{"->":"$r","var":true},null]}],{"c-31":["ev",{"^->":"demoROLLER.0.Success.c-31.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.4.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-5"},null],"c-32":["ev",{"^->":"demoROLLER.0.Success.c-32.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.5.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-5"},null]}],"g-5":["^How do you know?","\n","^A successful roll depends on the game rules, but usually you'll need to roll equal to or above a Target Number. This can be called the Difficulty or Challenge Rating, and I used Z to represent it in the functions.","\n","^[info side=accent]Term: Z represents Target Number. [/info]","\n","^A dice pool must either beat Z with the total_ of the pool, or with solo results.","\n","^Since total_ functions are simpler let's start there.","\n","ev","str","^DO I HAVE A CHOICE?","/str","/ev",{"*":".^.c-33","flg":4},{"c-33":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.SumTotalSuccess"},null]}],"SumTotalSuccess":["^[banner]CHECKING SUCCESS[/banner]","\n","^I said this was simple and it is. Checking success is asking if the total of X dY dice is equal to or greater than Z and returning 'true' or 'false'","\n","^I call functions that only return 'true' or 'false' 'check_' functions.","\n","^[info side=highlight]Function: check_success(roll, z) [/info]","\n","^Plus we'll include all the nice things we've already built too.","\n","^Roll 5 three-sided dice. To succeed you'll need to be equal to or greater than 10.","\n",["ev",{"^->":"demoROLLER.0.SumTotalSuccess.12.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-34","flg":2},{"s":["^ROLL THEM",{"->":"$r","var":true},null]}],{"c-34":["ev",{"^->":"demoROLLER.0.SumTotalSuccess.c-34.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.12.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.CheckSuccess"},null]}],"CheckSuccess":["^[info]","ev",5,3,10,{"f()":"narrate_XdYtotalZ"},"out","/ev","^[/info]","\n","^What this function is doing is running a tally_ to show_ the rolls and the total_ then check_success if the total_ is greater than Z. It uses that check_success to narrate_ either 'failed' or 'succeeded'.","\n","^[info side=highlight]Function: narrate_XdYtotalZ(x, y, z) [/info]","\n",[["ev",{"^->":"demoROLLER.0.CheckSuccess.g-6.0.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-35","flg":2},{"s":["^THAT WAS EASY ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-35":["ev",{"^->":"demoROLLER.0.CheckSuccess.g-6.c-35.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.0.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.^.g-7"},null],"#n":"g-6"}],null],"g-7":["^[banner]CHECKING POSSIBLE[/banner]","\n","^Let's add another check_. We want to make sure that success is possible.","\n","^So at the top of the narrate_ functions there's a check_ whether x multiplied by y (best_possible) is less than z.","\n","^[info side=accent]Function: check_possible(best_possible, z) [/info]","\n","^Here, roll these 3 two-sided dice. Try to beat 7.","\n",["ev",{"^->":"demoROLLER.0.g-7.10.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-36","flg":2},{"s":["^IF I MUST",{"->":"$r","var":true},null]}],{"c-36":["ev",{"^->":"demoROLLER.0.g-7.c-36.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.10.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-8"},null]}],"g-8":["^[info]","ev",3,2,7,{"f()":"narrate_XdYtotalZ"},"out","/ev","^[/info]","\n","^It's a handy check to include in all the narate functions - but make sure it's adjusted to the right formula for best possible, you don't want to be checking total_ instead of solo results.","\n","^It's also useful to block content or choices that are impossible to succeed.","\n","^[info] + {check_possible(best_possible, z)} Attack the Knight[/info]","\n",[["ev",{"^->":"demoROLLER.0.g-8.g-9.0.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-37","flg":2},{"s":["^ONWARD ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-37":["ev",{"^->":"demoROLLER.0.g-8.g-9.c-37.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.0.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.^.IndividualRollSuccess"},null],"#n":"g-9"}],null],"IndividualRollSuccess":["^[banner]INDIVIDUAL SUCCESS[/banner]","\n","^Right. How about testing individual rolls in a dice pool. Do any of the rolls meet or exceed z? How many?","\n",["ev",{"^->":"demoROLLER.0.IndividualRollSuccess.4.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-38","flg":2},{"s":["^YOU TELL ME",{"->":"$r","var":true},null]}],{"c-38":["ev",{"^->":"demoROLLER.0.IndividualRollSuccess.c-38.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.4.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-10"},null]}],"g-10":["^Alright, I will.","\n","^[info] ","ev",10,6,6,{"f()":"narrate__solosuccessXdYonZ"},"out","/ev","^[/info]","\n","^This is great for things such as successful number of attacks.","\n","^[info side=highlight]Function: narrate__solosuccessXdYonZ(x, y, z) [/info]","\n","^If you only need 1 roll to succeed in a pool then the total number of rolls that exceed it don't matter. The narrate_ part of the function gets a little tweak.","\n","^[info] ","ev",10,6,6,{"f()":"narrate__1successXdYonZ"},"out","/ev","^[/info]","\n","^[info side=highlight]Function: narrate__1successXdYonZ(x, y, z) [/info]","\n",[["ev",{"^->":"demoROLLER.0.g-10.g-11.0.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-39","flg":2},{"s":["^I WANT COUNTS TO COUNT ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-39":["ev",{"^->":"demoROLLER.0.g-10.g-11.c-39.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.0.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.^.SuccessCounts"},null],"#n":"g-11"}],null],"SuccessCounts":["^[banner]SUCCESSES & MORE SUCCESSES[/banner]","\n","^A second threshold for success?! So the dice need to beat Z and there needs to be enough of them.","\n","^But I reached Z. There are no more letters to use as stand-ins!","\n","^Fine. Let's use ST for 'Success Targets' - the number of successes needed to be successful.","\n","^[info side=accent]Term: ST the total_ of solo successes needed. [/info]","\n","^Bah. You're ruining this.","\n",["ev",{"^->":"demoROLLER.0.SuccessCounts.12.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-40","flg":2},{"s":["^I AM YOU",{"->":"$r","var":true},null]}],{"c-40":["ev",{"^->":"demoROLLER.0.SuccessCounts.c-40.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.12.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-12"},null]}],"g-12":["^What a terrible thought.","\n","^Anyway. This narrate_ function is only a slight variation of the others.","\n","^[info] ","ev",3,6,6,2,{"f()":"narrate__solosuccessXdYonZwST"},"out","/ev","^[/info]","\n","^[info side=highlight]Function: narrate__solosuccessXdYonZwST(x, y, z, st) [/info]","\n",[["ev",{"^->":"demoROLLER.0.g-12.g-13.0.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-41","flg":2},{"s":["^IS THAT EVERYTHING? ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-41":["ev",{"^->":"demoROLLER.0.g-12.g-13.c-41.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.0.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.^.Modifiers"},null],"#n":"g-13"}],null],"Modifiers":["^[banner]MODIFIERS[/banner]","\n","^We need to incorporate modifiers. Bonuses or penalties to the rolls. It's a pretty common feature.","\n",["ev",{"^->":"demoROLLER.0.Modifiers.4.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-42","flg":2},{"s":["^YOU'RE PRETTY COMMON",{"->":"$r","var":true},null]}],{"c-42":["ev",{"^->":"demoROLLER.0.Modifiers.c-42.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.4.s"},[{"#n":"$r2"}],"\n","^Rude. But true.","\n",{"->":".^.^.^.g-14"},null]}],"g-14":["^I use M to represent Modifiers. The value can be positive or negative.","\n","^[info side=accent]Term: M a value added to the total_ or solo roll. [/info]","\n","^Applying M is easy as long as the modifers are applied to the pool total, or to every roll in the pool equally.","\n","^The complicated version is applying different modifiers to individual rolls. I'm not going to make the complicated version.","\n",["ev",{"^->":"demoROLLER.0.g-14.8.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-43","flg":2},{"s":["^COWARD",{"->":"$r","var":true},null]}],{"c-43":["ev",{"^->":"demoROLLER.0.g-14.c-43.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.8.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-15"},null]}],"g-15":["^You're right - I'm afraid. Afraid of being psycho-analysed by anyone reading this.","\n","^Back on topic...","\n","ev","str","^PLEASE","/str","/ev",{"*":".^.c-44","flg":4},{"c-44":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.ModIndividual"},null]}],"ModIndividual":["^[banner]MODIFY EACH ROLL[/banner]","\n","^First let's apply M to each roll for individual successes.","\n","^Modifiers are narratively applied to the rolls, but mathematically there isn't a difference between adding M to each roll, or lowering the Z by M.","\n","^What this means is that M can be incorporated without changing the building block functions.","\n","^So here are 3 six-sided dice that need to beat 6, and each dice gets a +2 bonus.","\n",["ev",{"^->":"demoROLLER.0.ModIndividual.10.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-45","flg":2},{"s":["^ROLL EM!",{"->":"$r","var":true},null]}],{"c-45":["ev",{"^->":"demoROLLER.0.ModIndividual.c-45.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.10.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-16"},null]}],"g-16":["^[info]","ev",3,6,6,2,{"f()":"narrate_XdYonZwMe"},"out","/ev","^[/info]","\n","^[info side=highlight]Function: narrate_XdYonZwMe(x, y, z, m) [/info]","\n","^First let's apply M to each roll for individual successes.","\n","^Modifiers are narratively applied to the rolls, but mathematically there isn't a diffence between adding M to each roll, or lowering the Z by M.","\n","^What this means is that M can be incorporated without changing the building block functions.","\n","^So here are 3 six-sided dice that need to beat 6, and each dice gets a +2 bonus.","\n","^[info]","ev",3,6,6,2,{"f()":"narrate_XdYonZwMe"},"out","/ev","^[/info]","\n",["ev","str","^NEXT LESSON!","/str","/ev",{"*":".^.c-46","flg":4},{"c-46":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.^.ModTotal"},null],"#n":"g-17"}],null],"ModTotal":["^[banner]MODIFY THE SUM TOTAL[/banner]","\n","^And a bonus that's only applied to the Sum Total of a pool... Easy!","\n","^Roll 2 six-sided dice to beat 12. You have a +4 bonus.","\n","^[info]","ev",2,6,12,4,{"f()":"narrate_XdYonZwMt"},"out","/ev","^[/info]","\n","^[info side=highlight]Function: narrate_XdYonZwMe(x, y, z, m) [/info]","\n",[["ev",{"^->":"demoROLLER.0.ModTotal.g-18.0.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-47","flg":2},{"s":["^IS THAT IT?",{"->":"$r","var":true},null]}],{"c-47":["ev",{"^->":"demoROLLER.0.ModTotal.g-18.c-47.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.0.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.^.EndDemo"},null],"#n":"g-18"}],null],"EndDemo":["^That's it! For now.","\n","^I'll be adding more Ink resources and tutorials in the future. You can request features or topics in the comments.","\n","^I'm working on more TTRPG simulations right now, including Skill Checks and Dice Reserves.","\n","^<br>","\n","^If you found this useful, please send me a dollar via PayPal or donate on Itch. I'm in South Africa so a little goes a long way.","\n","^<br>","\n","^[info]www.paypal.com/paypalme/jonkeevy[/info]","\n","^You can find me with @jonkeevy most places. Except that one.","\n","^You can find Atrament UI at","\n","^[info]github.com/technix/atrament-web-ui[/info]","\n","ev","str","^ATRAMENT","/str","/ev",{"*":".^.c-48","flg":4},"ev","str","^GO TO CONTENTS","/str","/ev",{"*":".^.c-49","flg":4},"ev","str","^GOOD BYE","/str","/ev",{"*":".^.c-50","flg":4},{"c-48":["^ ","#","^CLEAR","/#","\n",{"->t->":"AtramentUI"},{"->":".^.^.^.g-19"},null],"c-49":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.Menu"},{"->":".^.^.^.g-19"},null],"c-50":["\n",{"->":".^.^.^.g-19"},null]}],"g-19":["end",null]}],null],"AtramentUI":[["^CLEAR ","#","^CLEAR","/#","\n","^[banner]ATRAMENT WEB UI[/banner]","\n","^Atrament Web UI is a web wrapper for Ink made by Serhii \"techniX\" Mozhaiskyi - big thanks to him. I'll try not to oversell Atrament and instead show you how I use it for dice rolling. (But also this whole demo is made with Atrament and uses its built-in features like banners, toolbars, call-out boxes, and - whoops I'm going into raving about Atrament again.","\n","^[info side=highlight] github.com/technix/atrament-web-ui [/info]","\n","^<br>","\n","^You'll need Atrament and also images of each dice face. I've included small, simple sets of three-sided, six-sided, and twenty-sided dice. You can make or find your own. You could even use gifs for a bit of animation.","\n","^[info][img]IMAGES/D3_3THREE.png[/img] ... [img]IMAGES/D6_6SIX.png[/img] ... [img]IMAGES/D20_20TWENTY.png[/img][/info]","\n",["ev",{"^->":"AtramentUI.0.17.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-0","flg":2},{"s":["^LET'S ROLL THEM ","#","^CLEAR","/#",{"->":"$r","var":true},null]}],{"c-0":["ev",{"^->":"AtramentUI.0.c-0.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.17.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.g-0"},null],"g-0":["^[banner]SHOW INLINE IMAGES[/banner]","\n","^It's pretty simple. I've used the rolling functions but added in a Switch Block.","\n",["ev",{"^->":"AtramentUI.0.g-0.4.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-1","flg":2},{"s":["^WHAT'S A SWITCH BLOCK?",{"->":"$r","var":true},null]}],["ev",{"^->":"AtramentUI.0.g-0.5.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-2","flg":2},{"s":["^I KNOW SWITCH BLOCKS",{"->":"$r","var":true},null]}],{"c-1":["ev",{"^->":"AtramentUI.0.g-0.c-1.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.4.s"},[{"#n":"$r2"}],"\n","^It's function that substitutes ('switches') one value for another. A bit like regex.","\n",{"->":".^.^.^.g-1"},null],"c-2":["ev",{"^->":"AtramentUI.0.g-0.c-2.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.5.s"},[{"#n":"$r2"}],"\n",{"->":".^.^.^.g-1"},null]}],"g-1":["^In this case it's switching the dice values for Atrament's inline image syntax. Which switch block we use depends on the number of sides the dice have. Unlike the text-only system you can't use XdY... you need to specify the Y to point at an image set you have. Since I included d3, d6 and d20 images we'll use those.","\n","^Here's the 'ATRMNT_IMGshow_' function:","\n","^[info side=highlight]2 three-sided dice ATRMNT_IMGshow_Xd3(5): ","ev",2,{"f()":"ATRMNT_IMGshow_Xd3"},"out","/ev","^[/info]","\n",["ev","str","^GOTCHA, DONE HERE","/str","/ev",{"*":".^.c-3","flg":4},{"c-3":["^ ","#","^CLEAR","/#","\n",{"->":".^.^.^.^.g-3"},null],"#n":"g-2"}],null],"g-3":["^Oh come on... roll the others!","\n","ev","str","^ROLL 4 d6s","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^ROLL 5 d20s","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^ROLL 9 d3s","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^NO","/str","/ev",{"*":".^.c-7","flg":4},{"c-4":["\n","^[info side=highlight]","ev",4,{"f()":"ATRMNT_IMGshow_Xd6"},"out","/ev","^[/info]","\n",{"->":".^.^.^.Leave"},null],"c-5":["\n","^[info side=highlight]","ev",5,{"f()":"ATRMNT_IMGshow_Xd20"},"out","/ev","^[/info]","\n",{"->":".^.^.^.Leave"},null],"c-6":["\n","^[info side=highlight]","ev",9,{"f()":"ATRMNT_IMGshow_Xd3"},"out","/ev","^[/info]","\n",{"->":".^.^.^.Leave"},null],"c-7":["\n",{"->":".^.^.^.Leave"},null]}],"Leave":["^Alright. Back to where you came from.","\n","ev","str","^BACK","/str","/ev",{"*":".^.c-8","flg":4},{"c-8":["^ ","#","^CLEAR","/#","\n","ev","void","/ev","->->",null]}]}],null],"game_toolbar":["^[button=GLOSSARY]GLOSSARY[/button]","\n",null],"GLOSSARY":["^[title]GLOSSARY[/title]","\n","^X is QUANTITY of dice rolled - also referred to as the POOL","\n","^Y is number of SIDES the dice have","\n","^Z is TARGET NUMBER - the number that the dice must equal or exceed either SOLO or as a TOTAL","\n","^ST is SUCCESS TARGET - the number of SOLO dice that must equal or exceed Z in a POOL for a GREATER SUCCESS","\n","^M is MODIFIER - the bonus or penalty applied to the roll either SOLO or TOTAL","\n","^POOL refers to the dice rolled collectively.","\n","^SOLO refers to individual dice in a POOL","\n","^TOTAL_ is a single combined INT value of a POOL","\n","^SHOW_ is a STRING showing the SOLO results of the individual dice in a POOL","\n","^TALLY_ is prints SHOW and returns a TOTAL","\n","^NARRATE_ presents other functions (like SHOW/TALLY/TOTAL) into sentences.","\n","^ATRMNT_IMG displays INLINE IMAGES of the rolled dice with Atrament markup.","\n",null]}],"listDefs":{}}