{"inkVersion":21,"root":[[["done",{"#n":"g-0"}],null],"done",{"court_clerk_intro":[["#","^speaker:Court Clerk","/#","#","^portrait:npc.clerk_01","/#","#","^sfx:paper_shuffle","/#","^Welcome to the Supreme Court, counselor. Are you here to suffer… I mean, study?","\n","ev","str","^Yes. Hit me.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Not today.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["^ ",{"->":"clerk_ready"},"\n",{"#f":5}],"c-1":["^ ",{"->":"clerk_later"},"\n",{"#f":5}]}],null],"clerk_ready":["#","^speaker:Court Clerk","/#","#","^portrait:npc.clerk_01","/#","#","^quest:set court_intro=true","/#","^Excellent! The Justices await in their chambers. Each one guards a domain of legal knowledge.","\n","#","^sfx:gavel_tap","/#","^Defeat them in flashcard combat to earn powerful outfits. Good luck, counselor.","\n","end",null],"clerk_later":["#","^speaker:Court Clerk","/#","#","^portrait:npc.clerk_01","/#","^Take your time. The law isn't going anywhere... unfortunately.","\n","end",null],"clerk_intro":[{"->":"court_clerk_intro"},null],"evidence_challenge":[["#","^speaker:Court Clerk","/#","#","^portrait:npc.clerk_01","/#","^Ready to test your knowledge of Evidence?","\n","ev","str","^Bring it on!","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Not yet...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=evidence count=3 rewardId=evidence_blazer","/#","end",{"#f":5}],"c-1":["\n","^Come back when you're ready.","\n","end",{"#f":5}]}],null],"justice_thomas_intro":[["#","^speaker:Justice Thomas","/#","#","^portrait:npc.justice_thomas","/#","#","^sfx:gavel_tap","/#","^Counselor. You dare challenge my command of the Rules of Evidence?","\n","^The hearsay exceptions alone have broken better lawyers than you.","\n","ev","str","^I'm ready, Your Honor.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Not yet...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=evidence count=5 rewardId=evidence_blazer","/#","end",{"#f":5}],"c-1":["\n","^Return when you've studied. The Federal Rules don't forgive ignorance.","\n","end",{"#f":5}]}],null],"justice_thomas_victory":["#","^speaker:Justice Thomas","/#","#","^portrait:npc.justice_thomas:impressed","/#","#","^give:evidence_blazer","/#","#","^quest:set defeated_thomas=true","/#","#","^sfx:victory_fanfare","/#","^Impressive. You know your hearsay from your admissions.","\n","^Wear this Evidence Blazer with pride, counselor.","\n","end",null],"justice_thomas_defeat":["#","^speaker:Justice Thomas","/#","#","^portrait:npc.justice_thomas:stern","/#","#","^sfx:defeat_sound","/#","^Objection sustained. Study the Federal Rules and return.","\n","end",null],"justice_roberts_intro":[["#","^speaker:Chief Justice Roberts","/#","#","^portrait:npc.justice_roberts","/#","#","^sfx:gavel_tap","/#","^Welcome to the highest court in the land, counselor.","\n","^Do you understand the Constitution well enough to argue before me?","\n","ev","str","^I'm prepared, Chief Justice.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I need more preparation...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=constitutional_law count=7 rewardId=conlaw_robe","/#","end",{"#f":5}],"c-1":["\n","^Wise. The Constitution rewards careful study.","\n","end",{"#f":5}]}],null],"justice_roberts_victory":["#","^speaker:Chief Justice Roberts","/#","#","^portrait:npc.justice_roberts:impressed","/#","#","^give:conlaw_robe","/#","#","^quest:set defeated_roberts=true","/#","#","^sfx:victory_fanfare","/#","^Outstanding constitutional analysis, counselor.","\n","^This Con Law Robe marks you as a true scholar of the founding document.","\n","end",null],"justice_roberts_defeat":["#","^speaker:Chief Justice Roberts","/#","#","^portrait:npc.justice_roberts:stern","/#","#","^sfx:defeat_sound","/#","^The Constitution is not so easily mastered. Study the amendments and return.","\n","end",null],"justice_sotomayor_intro":[["#","^speaker:Justice Sotomayor","/#","#","^portrait:npc.justice_sotomayor","/#","#","^sfx:gavel_tap","/#","^Counselor, criminal procedure is the shield of liberty.","\n","^Do you know when a search becomes unreasonable?","\n","ev","str","^Test me, Your Honor.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Let me review Miranda first...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=criminal_procedure count=5 rewardId=crimpro_badge","/#","end",{"#f":5}],"c-1":["\n","^A prudent choice. The Fourth and Fifth Amendments await.","\n","end",{"#f":5}]}],null],"justice_sotomayor_victory":["#","^speaker:Justice Sotomayor","/#","#","^portrait:npc.justice_sotomayor:impressed","/#","#","^give:crimpro_badge","/#","#","^quest:set defeated_sotomayor=true","/#","#","^sfx:victory_fanfare","/#","^Excellent work, counselor. You understand the rights of the accused.","\n","^This Crim Pro Badge is yours.","\n","end",null],"justice_sotomayor_defeat":["#","^speaker:Justice Sotomayor","/#","#","^portrait:npc.justice_sotomayor:concerned","/#","#","^sfx:defeat_sound","/#","^Remember: the Constitution protects the accused. Study harder.","\n","end",null],"justice_kagan_intro":[["#","^speaker:Justice Kagan","/#","#","^portrait:npc.justice_kagan","/#","#","^sfx:paper_shuffle","/#","^Ah, civil procedure. The rules that make litigation possible.","\n","^Personal jurisdiction, venue, Erie doctrine... ready to test your knowledge?","\n","ev","str","^Bring it on!","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I need to review the FRCP...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=civil_procedure count=5 rewardId=civpro_suit","/#","end",{"#f":5}],"c-1":["\n","^Fair enough. Those rules aren't going anywhere.","\n","end",{"#f":5}]}],null],"justice_kagan_victory":["#","^speaker:Justice Kagan","/#","#","^portrait:npc.justice_kagan:impressed","/#","#","^give:civpro_suit","/#","#","^quest:set defeated_kagan=true","/#","#","^sfx:victory_fanfare","/#","^Impressive procedural knowledge, counselor!","\n","^This Civ Pro Power Suit will serve you well in any courtroom.","\n","end",null],"justice_kagan_defeat":["#","^speaker:Justice Kagan","/#","#","^portrait:npc.justice_kagan:stern","/#","#","^sfx:defeat_sound","/#","^The Federal Rules are complex. Review Erie and come back.","\n","end",null],"justice_gorsuch_intro":[["#","^speaker:Justice Gorsuch","/#","#","^portrait:npc.justice_gorsuch","/#","#","^sfx:gavel_tap","/#","^Property law, counselor. The foundation of civilization itself.","\n","^Estates, future interests, the Rule Against Perpetuities...","\n","ev","str","^I've studied the estates.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^The Rule Against Perpetuities still confuses me...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=property count=5 rewardId=property_vest","/#","end",{"#f":5}],"c-1":["\n","^It confuses everyone. But study it you must.","\n","end",{"#f":5}]}],null],"justice_gorsuch_victory":["#","^speaker:Justice Gorsuch","/#","#","^portrait:npc.justice_gorsuch:impressed","/#","#","^give:property_vest","/#","#","^quest:set defeated_gorsuch=true","/#","#","^sfx:victory_fanfare","/#","^Well done! You understand property rights as well as any.","\n","^This Property Vest is your reward.","\n","end",null],"justice_gorsuch_defeat":["#","^speaker:Justice Gorsuch","/#","#","^portrait:npc.justice_gorsuch:stern","/#","#","^sfx:defeat_sound","/#","^Fee simple, life estate, remainder... study them all again.","\n","end",null],"justice_kavanaugh_intro":[["#","^speaker:Justice Kavanaugh","/#","#","^portrait:npc.justice_kavanaugh","/#","#","^sfx:paper_shuffle","/#","^Contracts, counselor. Offer, acceptance, consideration.","\n","^The UCC and common law dance together. Ready?","\n","ev","str","^I accept the challenge.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Let me review formation first...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=contracts count=5 rewardId=contracts_tie","/#","end",{"#f":5}],"c-1":["\n","^Consideration is key. Come back when you've thought it through.","\n","end",{"#f":5}]}],null],"justice_kavanaugh_victory":["#","^speaker:Justice Kavanaugh","/#","#","^portrait:npc.justice_kavanaugh:impressed","/#","#","^give:contracts_tie","/#","#","^quest:set defeated_kavanaugh=true","/#","#","^sfx:victory_fanfare","/#","^A binding performance, counselor!","\n","^This Contracts Tie symbolizes your mastery.","\n","end",null],"justice_kavanaugh_defeat":["#","^speaker:Justice Kavanaugh","/#","#","^portrait:npc.justice_kavanaugh:stern","/#","#","^sfx:defeat_sound","/#","^Breach of preparation. Review the Restatement and return.","\n","end",null],"justice_barrett_intro":[["#","^speaker:Justice Barrett","/#","#","^portrait:npc.justice_barrett","/#","#","^sfx:gavel_tap","/#","^Family law touches the most personal aspects of life, counselor.","\n","^Marriage, divorce, custody, support. Are you ready?","\n","ev","str","^I'm ready, Your Honor.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^This area requires more study...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=family_law count=5 rewardId=family_cardigan","/#","end",{"#f":5}],"c-1":["\n","^Family matters deserve careful attention. Take your time.","\n","end",{"#f":5}]}],null],"justice_barrett_victory":["#","^speaker:Justice Barrett","/#","#","^portrait:npc.justice_barrett:impressed","/#","#","^give:family_cardigan","/#","#","^quest:set defeated_barrett=true","/#","#","^sfx:victory_fanfare","/#","^Compassionate and competent, counselor.","\n","^This Family Law Cardigan is yours.","\n","end",null],"justice_barrett_defeat":["#","^speaker:Justice Barrett","/#","#","^portrait:npc.justice_barrett:concerned","/#","#","^sfx:defeat_sound","/#","^Family law requires sensitivity and knowledge. Study more.","\n","end",null],"justice_alito_intro":[["#","^speaker:Justice Alito","/#","#","^portrait:npc.justice_alito","/#","#","^sfx:gavel_tap","/#","^Criminal law, counselor. The definition of crimes and defenses.","\n","^Mens rea, actus reus, inchoate offenses. Let's see what you know.","\n","ev","str","^Challenge accepted.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I need to review the MPC...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=criminal_law count=5 rewardId=criminal_jacket","/#","end",{"#f":5}],"c-1":["\n","^The Model Penal Code awaits. Return when ready.","\n","end",{"#f":5}]}],null],"justice_alito_victory":["#","^speaker:Justice Alito","/#","#","^portrait:npc.justice_alito:impressed","/#","#","^give:criminal_jacket","/#","#","^quest:set defeated_alito=true","/#","#","^sfx:victory_fanfare","/#","^You know the elements of crime well, counselor.","\n","^This Criminal Law Jacket is your reward.","\n","end",null],"justice_alito_defeat":["#","^speaker:Justice Alito","/#","#","^portrait:npc.justice_alito:stern","/#","#","^sfx:defeat_sound","/#","^Guilty of insufficient preparation. Study the elements again.","\n","end",null],"justice_jackson_intro":[["#","^speaker:Justice Jackson","/#","#","^portrait:npc.justice_jackson","/#","#","^sfx:gavel_tap","/#","^Torts, counselor. Negligence, strict liability, intentional wrongs.","\n","^The duty of care awaits your analysis.","\n","ev","str","^I understand proximate cause.","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Let me review negligence first...","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n","#","^encounter:deckTag=torts count=5 rewardId=torts_blazer","/#","end",{"#f":5}],"c-1":["\n","^Breach, causation, damages. Master them and return.","\n","end",{"#f":5}]}],null],"justice_jackson_victory":["#","^speaker:Justice Jackson","/#","#","^portrait:npc.justice_jackson:impressed","/#","#","^give:torts_blazer","/#","#","^quest:set defeated_jackson=true","/#","#","^sfx:victory_fanfare","/#","^Excellent tort analysis, counselor!","\n","^This Torts Blazer suits you perfectly.","\n","end",null],"justice_jackson_defeat":["#","^speaker:Justice Jackson","/#","#","^portrait:npc.justice_jackson:concerned","/#","#","^sfx:defeat_sound","/#","^You've breached the duty of preparation. Study proximate cause and return.","\n","end",null],"librarian_intro":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","#","^sfx:book_open","/#","^Welcome to the Supreme Court Library, counselor.","\n","^I'm here to help you prepare for the challenges ahead.","\n","ev","str","^How does this place work?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Tell me about the Justices.","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Just browsing, thanks.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"librarian_tutorial"},{"#f":5}],"c-1":["\n",{"->":"librarian_justices"},{"#f":5}],"c-2":["\n","^Take your time. Knowledge is power in these halls.","\n","end",{"#f":5}]}],null],"librarian_tutorial":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Each Justice guards a domain of legal knowledge.","\n","^To earn their respect, you must defeat them in flashcard combat.","\n","#","^quest:set tutorial_started=true","/#","ev","str","^How do I win?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^What do I get for winning?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Thanks, I understand.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"librarian_combat"},{"#f":5}],"c-1":["\n",{"->":"librarian_rewards"},{"#f":5}],"c-2":["\n","end",{"#f":5}]}],null],"librarian_combat":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^In each encounter, you'll answer questions from a specific subject.","\n","^Get enough correct to defeat the Justice.","\n","^The more difficult the question, the more points you earn.","\n","ev","str","^What about the outfits?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Got it, thanks!","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_rewards"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"librarian_rewards":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Each Justice rewards their challenger with a powerful outfit.","\n","^These outfits grant special abilities in future encounters.","\n","^Hints, extra time, bonus points... collect them all!","\n","ev","str","^How do I unlock all areas?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I'm ready to challenge them!","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_progression"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"librarian_progression":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Some areas are locked until you've proven yourself.","\n","^Defeat all nine Justices to access the final challenge.","\n","^The Supreme Robe awaits the worthy.","\n","ev","str","^I'll do my best!","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","^Good luck, counselor. The law is on your side.","\n","end",{"#f":5}]}],null],"librarian_justices":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^There are nine Justices, each master of a different subject:","\n",["^Justice Thomas: Evidence","\n",["^Chief Justice Roberts: Constitutional Law","\n",["^Justice Sotomayor: Criminal Procedure","\n",["^Justice Kagan: Civil Procedure","\n",["^Justice Gorsuch: Property","\n","ev","str","^Continue...","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Thanks, that's enough.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_justices_2"},{"#f":5}],"c-1":["\n","end",{"#f":5}],"#n":"g-4"}],{"#n":"g-3"}],{"#n":"g-2"}],{"#n":"g-1"}],{"#n":"g-0"}],null],null],"librarian_justices_2":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#",["^Justice Kavanaugh: Contracts","\n",["^Justice Barrett: Family Law","\n",["^Justice Alito: Criminal Law","\n",["^Justice Jackson: Torts","\n","^Find them in their chambers throughout the courthouse.","\n","ev","str","^Where should I start?","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","^Start with the subject you know best. Build confidence first.","\n","end",{"#f":5}],"#n":"g-3"}],{"#n":"g-2"}],{"#n":"g-1"}],{"#n":"g-0"}],null],null],"bailiff_intro":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","#","^sfx:footstep_heavy","/#","^Halt. The main courtroom is off-limits.","\n","^Only those who have proven themselves may enter.","\n","ev","str","^What do I need to enter?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I'll come back later.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"bailiff_requirements"},{"#f":5}],"c-1":["\n","^See that you do. With proper credentials.","\n","end",{"#f":5}]}],null],"bailiff_requirements":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","^You must defeat all nine Justices in their chambers first.","\n","^Only then may you face the Chief Justice in the main courtroom.","\n","ev","str","^How many have I defeated?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I understand.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"bailiff_progress"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"bailiff_progress":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","^Check your progress in the menu.","\n","^Each defeated Justice is marked with their reward.","\n","ev","str","^Thanks.","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","end",{"#f":5}]}],null],"reporter_intro":[["#","^speaker:Court Reporter","/#","#","^portrait:npc.reporter","/#","#","^sfx:typing","/#","^Hello, counselor. I document everything that happens here.","\n","^I might have some useful information for you...","\n","ev","str","^Any tips for the challenges?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^What's the latest news?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Just passing through.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"reporter_tips"},{"#f":5}],"c-1":["\n",{"->":"reporter_news"},{"#f":5}],"c-2":["\n","end",{"#f":5}]}],null],"reporter_tips":[["#","^speake