{"inkVersion":21,"root":[[["done",{"#n":"g-0"}],null],"done",{"librarian_intro":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","#","^sfx:book_open","/#","^Welcome to the Supreme Court Library, counselor.","\n","^I'm here to help you prepare for the challenges ahead.","\n","ev","str","^How does this place work?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Tell me about the Justices.","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Just browsing, thanks.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"librarian_tutorial"},{"#f":5}],"c-1":["\n",{"->":"librarian_justices"},{"#f":5}],"c-2":["\n","^Take your time. Knowledge is power in these halls.","\n","end",{"#f":5}]}],null],"librarian_tutorial":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Each Justice guards a domain of legal knowledge.","\n","^To earn their respect, you must defeat them in flashcard combat.","\n","#","^quest:set tutorial_started=true","/#","ev","str","^How do I win?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^What do I get for winning?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Thanks, I understand.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"librarian_combat"},{"#f":5}],"c-1":["\n",{"->":"librarian_rewards"},{"#f":5}],"c-2":["\n","end",{"#f":5}]}],null],"librarian_combat":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^In each encounter, you'll answer questions from a specific subject.","\n","^Get enough correct to defeat the Justice.","\n","^The more difficult the question, the more points you earn.","\n","ev","str","^What about the outfits?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Got it, thanks!","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_rewards"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"librarian_rewards":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Each Justice rewards their challenger with a powerful outfit.","\n","^These outfits grant special abilities in future encounters.","\n","^Hints, extra time, bonus points... collect them all!","\n","ev","str","^How do I unlock all areas?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I'm ready to challenge them!","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_progression"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"librarian_progression":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^Some areas are locked until you've proven yourself.","\n","^Defeat all nine Justices to access the final challenge.","\n","^The Supreme Robe awaits the worthy.","\n","ev","str","^I'll do my best!","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","^Good luck, counselor. The law is on your side.","\n","end",{"#f":5}]}],null],"librarian_justices":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#","^There are nine Justices, each master of a different subject:","\n",["^Justice Thomas: Evidence","\n",["^Chief Justice Roberts: Constitutional Law","\n",["^Justice Sotomayor: Criminal Procedure","\n",["^Justice Kagan: Civil Procedure","\n",["^Justice Gorsuch: Property","\n","ev","str","^Continue...","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^Thanks, that's enough.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"librarian_justices_2"},{"#f":5}],"c-1":["\n","end",{"#f":5}],"#n":"g-4"}],{"#n":"g-3"}],{"#n":"g-2"}],{"#n":"g-1"}],{"#n":"g-0"}],null],null],"librarian_justices_2":[["#","^speaker:Law Librarian","/#","#","^portrait:npc.librarian","/#",["^Justice Kavanaugh: Contracts","\n",["^Justice Barrett: Family Law","\n",["^Justice Alito: Criminal Law","\n",["^Justice Jackson: Torts","\n","^Find them in their chambers throughout the courthouse.","\n","ev","str","^Where should I start?","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","^Start with the subject you know best. Build confidence first.","\n","end",{"#f":5}],"#n":"g-3"}],{"#n":"g-2"}],{"#n":"g-1"}],{"#n":"g-0"}],null],null],"bailiff_intro":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","#","^sfx:footstep_heavy","/#","^Halt. The main courtroom is off-limits.","\n","^Only those who have proven themselves may enter.","\n","ev","str","^What do I need to enter?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I'll come back later.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"bailiff_requirements"},{"#f":5}],"c-1":["\n","^See that you do. With proper credentials.","\n","end",{"#f":5}]}],null],"bailiff_requirements":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","^You must defeat all nine Justices in their chambers first.","\n","^Only then may you face the Chief Justice in the main courtroom.","\n","ev","str","^How many have I defeated?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^I understand.","/str","/ev",{"*":".^.c-1","flg":20},{"c-0":["\n",{"->":"bailiff_progress"},{"#f":5}],"c-1":["\n","end",{"#f":5}]}],null],"bailiff_progress":[["#","^speaker:Bailiff","/#","#","^portrait:npc.bailiff","/#","^Check your progress in the menu.","\n","^Each defeated Justice is marked with their reward.","\n","ev","str","^Thanks.","/str","/ev",{"*":".^.c-0","flg":20},{"c-0":["\n","end",{"#f":5}]}],null],"reporter_intro":[["#","^speaker:Court Reporter","/#","#","^portrait:npc.reporter","/#","#","^sfx:typing","/#","^Hello, counselor. I document everything that happens here.","\n","^I might have some useful information for you...","\n","ev","str","^Any tips for the challenges?","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^What's the latest news?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Just passing through.","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n",{"->":"reporter_tips"},{"#f":5}],"c-1":["\n",{"->":"reporter_news"},{"#f":5}],"c-2":["\n","end",{"#f":5}]}],null],"reporter_tips":[["#","^speaker:Court Reporter","/#","#","^portrait:npc.reporter","/#","^Each subject has its own patterns and tricks.","\n","^Pay attention to 